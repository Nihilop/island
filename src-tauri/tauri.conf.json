{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "island",
  "version": "0.3.0",
  "identifier": "com.nihil.island",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "island",
        "width": 1280,
        "height": 800,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "x": 0,
        "y": 0
      },
      {
        "label": "settings",
        "title": "Island — Réglages",
        "width": 760,
        "height": 560,
        "resizable": true,
        "visible": false,
        "decorations": false
      },
      {
        "label": "install",
        "title": "Island — Installation",
        "width": 540,
        "height": 560,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "center": true,
        "visible": false
      },
      {
        "label": "create",
        "title": "Island — Créer une extension",
        "width": 560,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["island"],
        "name": "Island Extension",
        "description": "Paquet d'extension Island"
      }
    ],
    "resources": ["icons/island-file.ico"]
  }
}
